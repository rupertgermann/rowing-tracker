{
  "name": "rowing-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered rowing workout tracker for SmartRow CSV exports with analytics, training plans, and achievement tracking",
  "author": "Rupert Germann",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rupertgermann/rowing-tracker.git"
  },
  "homepage": "https://github.com/rupertgermann/rowing-tracker",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:start": "docker-compose up -d",
    "db:stop": "docker-compose down",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:push": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "db:reset": "npx prisma migrate reset",
    "admin:promote": "npx tsx scripts/promote-admin.ts",
    "test": "npx tsx --test tests/*.test.ts",
    "test:e2e": "npx playwright test",
    "perf:pages": "node scripts/benchmark-page-loads.mjs",
    "perf:report": "node scripts/generate-page-load-report.mjs",
    "seed:mock": "npx tsx scripts/seed-mock-data.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@playwright/test": "^1.56.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.36.0",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.18.2",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.553.0",
    "next": "^16.2.4",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.7",
    "papaparse": "^5.5.3",
    "pg": "^8.16.3",
    "prisma": "^7.8.0",
    "react": "19.2.0",
    "react-day-picker": "^9.11.3",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.4.1",
    "remark-gfm": "^4.0.1",
    "remeda": "^2.32.0",
    "shiki": "^1.29.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "unpdf": "^1.4.0",
    "zod": "^4.2.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.5.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "overrides": {
    "@prisma/dev": {
      "@hono/node-server": "1.19.13",
      "hono": "4.12.18"
    },
    "cookie": "1.1.1",
    "nodemailer": "$nodemailer",
    "postcss": "8.5.13",
    "uuid": "14.0.0"
  }
}
