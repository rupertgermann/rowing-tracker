# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Choose ONE of the following database options:

# Option 1: Local Docker PostgreSQL (recommended for development)
# Start with: docker-compose up -d
DATABASE_URL="postgresql://rowing:rowing_dev_password@localhost:5432/rowing_tracker?schema=public"

# Option 2: Supabase (recommended for production)
# Get your connection string from: https://supabase.com/dashboard/project/_/settings/database
# Use the "Connection string" > "URI" format
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# For Prisma migrations with Supabase, use the direct connection (not pooled)
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# =============================================================================
# AUTHENTICATION (NextAuth.js)
# =============================================================================

# Required: Secret for encrypting session tokens
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Required: Your application URL
NEXTAUTH_URL="http://localhost:3000"

# Optional: Google OAuth (for "Sign in with Google")
# Get credentials from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Local development with Mailpit (docker-compose up -d)
EMAIL_SERVER="smtp://localhost:1025"
EMAIL_FROM="Rowing Tracker <noreply@rowing-tracker.local>"

# Production SMTP (e.g., SendGrid, AWS SES, etc.)
# EMAIL_SERVER="smtp://username:password@smtp.sendgrid.net:587"
# EMAIL_FROM="Rowing Tracker <noreply@yourdomain.com>"

# =============================================================================
# OPENAI API CONFIGURATION
# =============================================================================

# Get your API key from https://platform.openai.com/api-keys
# Note: Users can also configure their own API key in Settings → AI Coach.
# This env var serves as a fallback and is exposed to the client (NEXT_PUBLIC_ prefix).
# NEXT_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI endpoint (for Azure or other compatible APIs)
# NEXT_PUBLIC_OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# REDIS CONFIGURATION (for rate limiting)
# =============================================================================

UPSTASH_REDIS_REST_URL="your-upstash-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"